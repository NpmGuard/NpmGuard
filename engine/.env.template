# Engine — Environment Template
# Copy to .env and fill in real values.

# API server
NPMGUARD_API_HOST=0.0.0.0
NPMGUARD_API_PORT=8000

# LLM backend: "anthropic", "google", or "openai_compatible"
NPMGUARD_LLM_BACKEND=openai_compatible
NPMGUARD_LLM_API_KEY=
NPMGUARD_LLM_TIMEOUT_SECONDS=60

# OpenAI-compatible examples:
#   Google Gemini: https://generativelanguage.googleapis.com/v1beta/openai
#   OpenRouter:    https://openrouter.ai/api/v1
#   MiniMax:       https://api.minimax.io/v1
NPMGUARD_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Payment gate. Production should stay true; set false only for local/dev runs.
NPMGUARD_PAYMENT_REQUIRED=true

# Chain payment verification (server-side only)
NPMGUARD_BASE_SEPOLIA_CONTRACT=
NPMGUARD_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Per-phase models
NPMGUARD_TRIAGE_MODEL=gemini-2.5-flash
NPMGUARD_TRIAGE_MAX_FILES=80
NPMGUARD_INVESTIGATION_MODEL=gemini-2.5-flash
NPMGUARD_TEST_GEN_MODEL=gemini-2.5-flash

# MiniMax M3 test profile:
# NPMGUARD_LLM_BACKEND=openai_compatible
# NPMGUARD_LLM_BASE_URL=https://api.minimax.io/v1
# NPMGUARD_TRIAGE_MODEL=MiniMax-M3
# NPMGUARD_INVESTIGATION_MODEL=MiniMax-M3
# NPMGUARD_TEST_GEN_MODEL=MiniMax-M3
