# Engine — Environment Template
# Copy to .env and fill in real values.

# API server
NPMGUARD_API_HOST=0.0.0.0
NPMGUARD_API_PORT=8000

# LLM backend: "anthropic", "google", or "openai_compatible"
NPMGUARD_LLM_BACKEND=openai_compatible
NPMGUARD_LLM_API_KEY=
NPMGUARD_LLM_MODEL=deepseek/deepseek-v4-flash
NPMGUARD_LLM_TIMEOUT_SECONDS=60

# OpenAI-compatible examples:
#   OpenRouter:    https://openrouter.ai/api/v1
#   Google Gemini: https://generativelanguage.googleapis.com/v1beta/openai
#   MiniMax:       https://api.minimax.io/v1
#   DeepSeek:      https://api.deepseek.com
NPMGUARD_LLM_BASE_URL=https://openrouter.ai/api/v1

# Payment gate. Production should stay true; set false only for local/dev runs.
NPMGUARD_PAYMENT_REQUIRED=true

# Chain payment verification (server-side only)
NPMGUARD_BASE_SEPOLIA_CONTRACT=
NPMGUARD_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional report/package publication for demos (server-side only)
# The report store remains data/reports/<pkg>/<version>.json; this publishes
# copies to Pinata and, when ENS vars are set, writes npmguard.* ENS text records.
NPMGUARD_PINATA_JWT=
NPMGUARD_PINATA_GATEWAY_HOST=gateway.pinata.cloud
NPMGUARD_PINATA_NETWORK=public
NPMGUARD_ENS_ROOT_DOMAIN=npmguard-demo.eth
NPMGUARD_ENS_REGISTRY_VERSION=auto
NPMGUARD_ENS_RPC_URL=
NPMGUARD_ENS_PRIVATE_KEY=
# Optional Sepolia ENS deployment overrides:
# NPMGUARD_ENS_REGISTRY_ADDRESS=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
# NPMGUARD_ENS_NAME_WRAPPER_ADDRESS=0x0635513f179D50A207757E05759CbD106d7dFcE8
# NPMGUARD_ENS_PUBLIC_RESOLVER_ADDRESS=0xE99638b40E4Fff0129D56f03b55b6bbC4BBE49b5
# NPMGUARD_ENS_UNIVERSAL_RESOLVER_ADDRESS=0xeEeEEEeE14D718C2B47D9923Deab1335E144EeEe
# NPMGUARD_ENS_V2_REGISTRY_ADDRESS=0xDEDB92913A25abE1f7BCDD85D8A344a43B398B67
# NPMGUARD_ENS_V2_RESOLVER_FACTORY_ADDRESS=0xd2A632D8A8b67C2c4398c255CBd7Af8Dd7236198
# NPMGUARD_ENS_V2_SUBREGISTRY_IMPLEMENTATION_ADDRESS=0x0F99e7Ea74903AfCB7224d0354fD7428A6f92917

# Optional per-phase model overrides. If unset, NPMGUARD_LLM_MODEL is used.
NPMGUARD_TRIAGE_MODEL=deepseek/deepseek-v4-flash
NPMGUARD_TRIAGE_MAX_FILES=80
NPMGUARD_INVESTIGATION_MODEL=deepseek/deepseek-v4-flash
NPMGUARD_TEST_GEN_MODEL=deepseek/deepseek-v4-flash

# MiniMax M3 test profile:
# NPMGUARD_LLM_BACKEND=openai_compatible
# NPMGUARD_LLM_BASE_URL=https://api.minimax.io/v1
# NPMGUARD_TRIAGE_MODEL=MiniMax-M3
# NPMGUARD_INVESTIGATION_MODEL=MiniMax-M3
# NPMGUARD_TEST_GEN_MODEL=MiniMax-M3

# OpenRouter DeepSeek V4 Flash test profile:
# NPMGUARD_LLM_BACKEND=openai_compatible
# NPMGUARD_LLM_BASE_URL=https://openrouter.ai/api/v1
# NPMGUARD_LLM_API_KEY=$OPENROUTER_API_KEY
# NPMGUARD_TRIAGE_MODEL=deepseek/deepseek-v4-flash
# NPMGUARD_INVESTIGATION_MODEL=deepseek/deepseek-v4-flash
# NPMGUARD_TEST_GEN_MODEL=deepseek/deepseek-v4-flash

# Direct DeepSeek test profile:
# NPMGUARD_LLM_BACKEND=openai_compatible
# NPMGUARD_LLM_BASE_URL=https://api.deepseek.com
# NPMGUARD_LLM_API_KEY=$DEEPSEEK_API_KEY
