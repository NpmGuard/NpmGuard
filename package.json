{
  "name": "npmguard-test-suite",
  "private": true,
  "type": "commonjs",
  "workspaces": [
    "shared",
    "engine",
    "frontend",
    "bench"
  ],
  "scripts": {
    "dev": "./run.sh",
    "dev:engine": "cd engine && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:shared": "npm -w @npmguard/shared run build",
    "test": "vitest run --root sandbox",
    "test:watch": "vitest --root sandbox"
  },
  "devDependencies": {
    "jsdom": "^26.0.0",
    "msw": "^2.12.14",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "axios": "^1.14.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.27.7": true
  }
}
