# Bench malware fixtures — actively malicious npm packages extracted from the
# Datadog corpus. Regenerable via `npm run -w @npmguard/bench datadog:fetch`.
# NEVER commit these to git — they would re-host live malware in this repo.
sandbox/test-fixtures/test-pkg-bench-dd-*/

# Bench runner manifest is regenerable from bench/dataset/datadog/corpus.json.
bench/dataset/manifest.json

# Audit reports — generated outputs, persisted per-environment (prod droplet has
# its own data/ dir). Don't commit local test runs; they conflict with prod.
data/reports/

# Sandbox runtime deps installed at bench time.
sandbox/package.json
sandbox/package-lock.json
sandbox/node_modules/

# Claude Code session transcript dumps accidentally left in the repo root.
# e.g. 2026-05-04-220442-this-session-is-being-continued-from-a-previous-c.txt
[0-9][0-9][0-9][0-9]-*-this-session-is-being-continued-from-a-previous-*.txt

# SQLite panel DB (users/sessions/scans) — local state, never commit.
data/npmguard.db*
