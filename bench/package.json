{
  "name": "@npmguard/bench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Security mutation testing benchmark for the NpmGuard auditor.",
  "scripts": {
    "lock": "tsx src/seeds/lock.ts",
    "fetch": "tsx src/seeds/fetch.ts",
    "verify-loads": "tsx src/seeds/verify-loads.ts",
    "datadog:select": "tsx src/datadog/select.ts",
    "datadog:fetch": "tsx src/datadog/fetch.ts",
    "datadog:manifest": "tsx src/datadog/manifest.ts",
    "run": "tsx src/runner/audit-all.ts",
    "aggregate:v3": "tsx src/runner/aggregate-audits.ts",
    "analyze": "tsx src/runner/analyze.ts",
    "manifest:v3": "tsx src/runner/manifest-from-audits.ts",
    "manifest:v1.1": "tsx src/runner/build-v1_1-manifest.ts",
    "summarize:v3": "tsx src/runner/summarize-v3.ts",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@npmguard/shared": "*",
    "tar": "^7.4.3",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3"
  }
}
