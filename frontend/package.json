    "@uiw/react-codemirror": "^4.25.9",
    "lucide-react": "^1.26.0",
    "motion": "^12.42.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^8.1.0",
    "viem": "^2.47.19",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
